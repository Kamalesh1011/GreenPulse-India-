# ============================================================
#  GreenPulse India — .gitignore
# ============================================================

# --- Environment / secrets ---
.env
.env.local
.env.*
!.env.example          # always commit the template

# --- Virtual environments ---
.venv/
venv/
ENV/
env/
bin/
include/
lib/
lib64/
share/
pyvenv.cfg

# --- Python build artifacts ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# --- Project runtime files ---
sensor_stream.jsonl    # Kafka fallback file (runtime-generated)
*.log

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Docker ---
.docker/

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/

# --- Type checking ---
.mypy_cache/
